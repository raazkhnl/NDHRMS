# ─── API base URL ───
# Local development: points to local Express on port 5000
VITE_API_BASE_URL=http://localhost:5000/api

# Production: set this to your Vercel server project URL
# VITE_API_BASE_URL=https://ndhrms-server.vercel.app/api

# ─── Build target ───
# 'development' | 'staging' | 'production'
VITE_ENVIRONMENT=development
