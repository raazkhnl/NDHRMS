# ─── MongoDB connection ───
# Production: MongoDB Atlas
MONGODB_URI=mongodb+srv://pscadmin:YOUR_PASSWORD@cluster0.xxxxx.mongodb.net/psc_system?retryWrites=true&w=majority

# Local dev / docker-compose — change if using docker service name 'mongo'
# MONGODB_URI=mongodb://localhost:27017/psc_system

# ─── Server ───
PORT=5000
NODE_ENV=development

# ─── JWT ───
# CHANGE THIS in production. Generate with: openssl rand -hex 32
JWT_SECRET=psc_nepal_super_secret_2026_CHANGE_ME_IN_PRODUCTION
JWT_EXPIRES_IN=24h

# ─── CORS ───
# Comma-separated list of allowed origins (no trailing slashes)
# Local dev:
CLIENT_ORIGIN=http://localhost:5173
# Production (add your Vercel client URL, keeping localhost for local access):
# CLIENT_ORIGIN=https://ndhrms.vercel.app,http://localhost:5173
